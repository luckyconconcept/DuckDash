{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "duck-dash",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "-e",
        "const http=require('http'),fs=require('fs'),path=require('path');const ROOT='/Users/kluck/Downloads/Duck&Dash/building-challenge-starter';const M={'.html':'text/html','.js':'text/javascript','.css':'text/css','.png':'image/png','.jpg':'image/jpeg','.jpeg':'image/jpeg'};http.createServer((q,s)=>{let p=decodeURIComponent(q.url.split('?')[0]);if(p==='/')p='/index.html';const f=path.join(ROOT,p);fs.readFile(f,(e,d)=>{if(e){s.writeHead(404);s.end('nf')}else{s.writeHead(200,{'Content-Type':M[path.extname(f)]||'application/octet-stream'});s.end(d)}})}).listen(4288,()=>console.log('serving on 4288'))"
      ],
      "port": 4288
    }
  ]
}
